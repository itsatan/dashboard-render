{
    "name": "idea-render",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev": "npm-run-all --parallel dev:*",
        "dev:frontend": "npm -C frontend run dev",
        "dev:backend": "npm -C backend run dev",
        "build": "npm-run-all build:*",
        "build:frontend": "npm -C frontend run build",
        "build:backend": "npm -C backend run build",
        "install:all": "npm -C frontend install && npm -C backend install"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5"
    }
}
